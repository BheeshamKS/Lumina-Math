GEMINI_API_KEY=...                                                                                                                              
GROQ_API_KEY=...  

# ── Supabase ────────────────────────────────────────────────────────
# Project URL  → Supabase dashboard > Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Anon/public key  → Settings > API > Project API keys > anon / public
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# JWT secret  → Settings > API > JWT Settings > JWT Secret
# Used server-side to verify Supabase-issued JWTs
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── Database ────────────────────────────────────────────────────────
# Postgres connection string → Supabase dashboard > Settings > Database > Connection string (URI mode)
# Use the "Transaction" pooler URI on port 6543 for serverless, or direct on 5432
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Server ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

